module {{ DUT }}_checker
{%- if parameter_items %}
  #(
  {%- for key, value in parameter_items %}
    parameter {{ key }} = {{ value }}{{ "," if not loop.last }}
  {%- endfor %}
  )
{%- endif %}
(
{%- if header_ports %}
  {{ header_ports | join(',\n  ') }}
{%- endif %}
);

{%- if clock_reset_aliases %}
  // Auto-generated aliases from generic env clk/rst_n to DUT-local clock/reset names
{%- for alias in clock_reset_aliases %}
  {{ alias.declaration }};
  assign {{ alias.name }} = {{ alias.expr }};
{%- endfor %}
{%- endif %}

  // Auto-generated checker skeleton from .formal_records.yaml
{%- if has_clock %}
  default clocking cb @({{ clock_edge or 'posedge' }} {{ clock_signal or 'clk' }}); endclocking
{%- endif %}
{%- if has_reset %}
  default disable iff ({{ reset_disable_expr or '!rst_n' }});
{%- endif %}

{% for ck in check_points %}
  // {{ ck.description }}
  // Style: {{ ck.style }}{{ "  [AUTO-ADDED]" if ck.is_new else "" }}
  property {{ ck.prop_name }};
{{ ck.sva_body | indent(4, first=True) }}
  endproperty
  {{ ck.label }}: {{ ck.kind }} property ({{ ck.prop_name }});

{% endfor %}
endmodule
