module {{ DUT }}_wrapper
{%- if parameter_items %}
  #(
  {%- for key, value in parameter_items %}
    parameter {{ key }} = {{ value }}{{ "," if not loop.last }}
  {%- endfor %}
  )
{%- endif %}
(
{%- set port_items = [] %}
{%- if has_clock %}{% set _ = port_items.append('input ' ~ (clock_signal or 'clk')) %}{% endif %}
{%- if has_reset %}{% set _ = port_items.append('input ' ~ (reset_signal or 'rst_n')) %}{% endif %}
{%- if port_items %}
  {{ port_items | join(',\n  ') }}
{%- endif %}
);

  // Auto-generated symbolic signals
{% for decl in internal_decls %}
  {{ decl }};
{%- endfor %}

{%- if whitebox_signals %}
  // Manual whitebox signals
{%- for sig in whitebox_signals %}
  {{ sig.declaration }};
{%- endfor %}
{%- endif %}

{%- if clock_reset_aliases %}
  // Auto-generated aliases from generic env clk/rst_n to DUT-local clock/reset names
{%- for alias in clock_reset_aliases %}
  {{ alias.declaration }};
  assign {{ alias.name }} = {{ alias.expr }};
{%- endfor %}
{%- endif %}

  {{ DUT }} 
{%- if parameter_items %}
  #(
  {%- for key, value in parameter_items %}
    .{{ key }}({{ key }}){{ "," if not loop.last }}
  {%- endfor %}
  ) 
{%- endif %}
  u_dut (
    {{ dut_connections | join(',\n    ') }}
  );

{%- if whitebox_signals %}
{%- for sig in whitebox_signals %}
  assign {{ sig.name }} = u_dut.{{ sig.name }};
{%- endfor %}
{%- endif %}

  {{ DUT }}_checker 
{%- if parameter_items %}
  #(
  {%- for key, value in parameter_items %}
    .{{ key }}({{ key }}){{ "," if not loop.last }}
  {%- endfor %}
  ) 
{%- endif %}
  u_checker (
    {{ checker_connections | join(',\n    ') }}
  );

endmodule
